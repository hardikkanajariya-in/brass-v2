{
  "colors": {
    "brand": {
      "primary": "#0F766E",
      "primaryLight": "#14B8A6",
      "primaryDark": "#0D5B56",
      "secondary": "#1E293B",
      "secondaryLight": "#334155",
      "secondaryDark": "#0F172A"
    },
    "neutral": {
      "50": "#F8FAFC",
      "100": "#F1F5F9",
      "200": "#E2E8F0",
      "300": "#CBD5E1",
      "400": "#94A3B8",
      "500": "#64748B",
      "600": "#475569",
      "700": "#334155",
      "800": "#1E293B",
      "900": "#0F172A",
      "950": "#020617"
    },
    "semantic": {
      "success": "#16A34A",
      "warning": "#D97706",
      "error": "#DC2626",
      "info": "#2563EB"
    },
    "surface": {
      "default": "#F8FAFC",
      "muted": "#F1F5F9",
      "inverse": "#1E293B"
    }
  },
  "typography": {
    "fontFamily": {
      "heading": "Poppins",
      "body": "Poppins"
    },
    "fontSize": {
      "xs": { "size": "0.75rem", "lineHeight": "1rem", "letterSpacing": "0.025em" },
      "sm": { "size": "0.875rem", "lineHeight": "1.25rem", "letterSpacing": "0.015em" },
      "base": { "size": "1rem", "lineHeight": "1.5rem", "letterSpacing": "0" },
      "lg": { "size": "1.125rem", "lineHeight": "1.75rem", "letterSpacing": "-0.01em" },
      "xl": { "size": "1.25rem", "lineHeight": "1.75rem", "letterSpacing": "-0.015em" },
      "2xl": { "size": "1.5rem", "lineHeight": "2rem", "letterSpacing": "-0.02em" },
      "3xl": { "size": "1.875rem", "lineHeight": "2.25rem", "letterSpacing": "-0.025em" },
      "4xl": { "size": "2.25rem", "lineHeight": "2.5rem", "letterSpacing": "-0.03em" },
      "5xl": { "size": "3rem", "lineHeight": "1.15", "letterSpacing": "-0.035em" }
    },
    "fontWeight": {
      "light": 300,
      "normal": 400,
      "medium": 500,
      "semibold": 600,
      "bold": 700
    }
  },
  "spacing": {
    "section": "5rem",
    "sectionMobile": "3rem",
    "container": "1.25rem",
    "cardPadding": "1.5rem",
    "inputPadding": "0.75rem",
    "cardGap": "1.5rem"
  },
  "radius": {
    "sm": "0.25rem",
    "md": "0.5rem",
    "lg": "0.75rem",
    "xl": "1rem",
    "full": "9999px",
    "card": "0.75rem",
    "button": "0.5rem",
    "input": "0.5rem"
  },
  "shadow": {
    "sm": "0 1px 2px 0 rgb(0 0 0 / 0.05)",
    "md": "0 4px 6px -1px rgb(0 0 0 / 0.1), 0 2px 4px -2px rgb(0 0 0 / 0.1)",
    "lg": "0 10px 15px -3px rgb(0 0 0 / 0.1), 0 4px 6px -4px rgb(0 0 0 / 0.1)",
    "card": "0 2px 8px -2px rgb(15 118 110 / 0.10), 0 4px 12px -4px rgb(0 0 0 / 0.08)",
    "dropdown": "0 8px 24px -4px rgb(0 0 0 / 0.18)",
    "button": "0 2px 6px -1px rgb(15 118 110 / 0.30)"
  },
  "gradients": {
    "hero": "linear-gradient(135deg, #0F172A 0%, #1E293B 50%, #334155 100%)",
    "brass": "linear-gradient(135deg, #0D5B56 0%, #14B8A6 100%)",
    "surface": "linear-gradient(180deg, #F8FAFC 0%, #F1F5F9 100%)"
  },
  "animation": {
    "duration": {
      "fast": "150ms",
      "normal": "300ms",
      "slow": "500ms"
    },
    "easing": {
      "default": "cubic-bezier(0.4, 0, 0.2, 1)",
      "bounce": "cubic-bezier(0.34, 1.56, 0.64, 1)"
    }
  },
  "container": {
    "maxWidth": "1280px",
    "maxWidthWide": "1440px"
  }
}
